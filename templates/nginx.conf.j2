user nginx;
worker_processes auto;
error_log /var/log/nginx/error.log notice;
pid /var/run/nginx.pid;

events {
    worker_connections 1024;
}

http {
    include /etc/nginx/mime.types;
    default_type application/octet-stream;
    sendfile on;
    keepalive_timeout 65;

    upstream devops_lvl2_backend {
        server web1:{{ redmine_port }};
        server web2:{{ redmine_port }};
    }

    server {
        listen 80;
        server_name {{ redmine_domain }} www.{{ redmine_domain }} example.local www.example.local localhost;
        return 301 https://$host$request_uri;
    }

    server {
        listen 443 ssl;
        server_name {{ redmine_domain }} www.{{ redmine_domain }} example.local www.example.local localhost;

        ssl_certificate /etc/nginx/certs/devops.example.crt;
        ssl_certificate_key /etc/nginx/certs/devops.example.key;

        location / {
            proxy_pass http://devops_lvl2_backend;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto https;
        }
    }
}
